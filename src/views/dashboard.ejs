<div class="flex-1 min-w-0 max-h-screen overflow-scroll" x-data="dashboardApp()" x-init="init()">
    <template x-if="!isLoggedIn">
      <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4">
        <div class="w-full max-w-md rounded-2xl border-2 border-base-content/10 bg-base-100 p-6 text-center shadow-2xl">
          <div class="text-4xl mb-3">🔒</div>
          <h2 class="font-serif text-2xl font-semibold text-base-content">Belum Login</h2>
          <p class="mt-2 text-sm text-base-content/70">Silakan masuk terlebih dahulu untuk melihat dashboard user.</p>
          <a href="/login" class="btn btn-primary mt-5 w-full">Masuk ke Akun</a>
        </div>
      </div>
    </template>


    <main class="flex-grow w-full max-w-7xl mx-auto px-5 py-6 space-y-6 pb-32">
      <section class="space-y-3">
        <div class="inline-block px-3 py-1 rounded-full bg-base-100/20 backdrop-blur-sm border-2 border-base-content/10">
          <span class="font-sans text-primary tracking-widest uppercase text-sm">Mode Pelanggan</span>
        </div>
        <div>
          <h2 class="font-serif text-2xl font-semibold text-base-content">Selamat Datang Kembali</h2>
          <div class="flex items-center space-x-4 mt-2">
            <span class="font-sans text-base-content/70"><%= new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
          </div>
        </div>
      </section>

      <!-- Stats -->
      <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-primary p-4 rounded-xl flex flex-col justify-between aspect-square shadow-[0_4px_20px_rgba(200,151,58,0.2)]">
          <div class="flex justify-between items-start">
            📅
            <span class="font-sans text-primary-content text-sm font-semibold">Bulan Ini</span>
          </div>
          <div>
            <h3 class="font-serif text-3xl font-bold text-primary-content" x-text="totalBookings"></h3>
            <p class="font-sans text-primary-content opacity-90 mt-1">Total Booking</p>
          </div>
        </div>
        <div class="bg-base-100/20 backdrop-blur-sm p-6 rounded-2xl border-2 border-base-content/10 flex flex-col justify-between aspect-square">
          <div class="flex justify-between items-start">
            ⌛
          </div>
          <div>
            <h3 class="font-serif text-3xl font-bold text-base-content" x-text="pendingBookings"></h3>
            <p class="font-sans text-base-content/70 mt-1">Booking Menunggu</p>
          </div>
        </div>
        <div class="bg-base-100/20 backdrop-blur-sm p-6 rounded-2xl border-2 border-base-content/10 flex flex-col justify-between aspect-square">
          ✅
          <div>
            <h3 class="font-serif text-3xl font-bold text-base-content" x-text="completedBookings"></h3>
            <p class="font-sans text-base-content/70 mt-1">Booking Selesai</p>
          </div>
        </div>
        <div class="bg-base-100/20 backdrop-blur-sm p-6 rounded-2xl border-2 border-base-content/10 flex flex-col justify-between aspect-square">
          ⭐
          <div>
            <h3 class="font-serif text-3xl font-bold text-base-content">4.9</h3>
            <p class="font-sans text-base-content/70 mt-1">Rating Rata-rata</p>
          </div>
        </div>
      </section>

      <!-- Booking History -->
      <section class="space-y-4">
        <div class="flex justify-between items-center">
          <h3 class="font-serif text-xl font-semibold text-base-content">Riwayat Booking Terakhir</h3>
          <a class="font-sans text-primary hover:underline text-sm" href="/booking">Lihat Semua</a>
        </div>
        
        <template x-if="recentBookings.length > 0">
          <div class="space-y-2">
            <template x-for="booking in recentBookings" :key="booking.id">
              <div class="bg-base-100/20 backdrop-blur-sm p-4 rounded-2xl border-2 border-base-content/10 flex justify-between items-center">
                <div>
                  <p class="font-semibold text-base-content" x-text="booking.serviceName"></p>
                  <p class="text-sm text-base-content/70" x-text="booking.date + ' • ' + booking.barberName"></p>
                </div>
                <span class="text-sm font-semibold px-3 py-1 rounded-full" :class="booking.status === 'completed' ? 'bg-success/20 text-success' : booking.status === 'pending' ? 'bg-warning/20 text-warning' : 'bg-base-300 text-base-content/70'" x-text="booking.statusLabel"></span>
              </div>
            </template>
          </div>
        </template>
        
        <template x-if="recentBookings.length === 0">
          <div class="bg-base-100/20 backdrop-blur-sm rounded-2xl p-6 text-center border-2 border-base-content/10">
            <p class="text-base-content/70">Belum ada booking</p>
            <a href="/booking" class="btn btn-sm btn-primary mt-2">Buat Booking</a>
          </div>
        </template>
      </section>
    </main>

<script>
function dashboardApp() {
  return {
    currentPage: 'dashboard',
    theme: localStorage.getItem('barbersync-theme') || 'coffee',
    user: null,
    totalBookings: 12,
    pendingBookings: 2,
    completedBookings: 10,

    get isLoggedIn() {
      return !!this.user;
    },

    recentBookings: [
      { id: 1, serviceName: 'Potong Rambut', barberName: 'Ahmad Syaiful', date: '12 Mei 2026', status: 'completed', statusLabel: 'Selesai' },
      { id: 2, serviceName: 'Fade Cream', barberName: 'Budi Santoso', date: '11 Mei 2026', status: 'completed', statusLabel: 'Selesai' },
      { id: 3, serviceName: 'Beard Trim', barberName: 'Charlie Rahman', date: '10 Mei 2026', status: 'pending', statusLabel: 'Menunggu' }
    ],
    
    setTheme(value) {
      this.theme = value;
      document.documentElement.setAttribute('data-theme', value);
      localStorage.setItem('barbersync-theme', value);
    },
    
    init() {
      this.setTheme(this.theme);

      try {
        const stored = localStorage.getItem('barbersync-user');
        if (stored) {
          this.user = JSON.parse(stored);
        }
      } catch (e) {}

      if (this.user && this.user.role === 'admin') {
        window.location.href = '/admin';
      }
    }
  };
}
</script>
</div>
