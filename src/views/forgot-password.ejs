<div class="lg:flex lg:min-h-screen" x-data="forgotPasswordApp()" x-init="init()">
  <div class="flex-1 min-w-0 flex flex-col gap-6 px-4 py-4">
    <%- include('partials/header', { showBack: true, pageTitle: 'Lupa Kata Sandi', showLoginNav: false }) %>

    <div class="flex-1 min-w-0 flex items-center justify-center py-8">
      <div class="w-full max-w-md">
        <div class="bg-base-100/30 backdrop-blur-sm rounded-2xl p-8 border-2 border-base-content/10 space-y-6">
          <div class="text-center">
            <h1 class="font-['Noto_Serif'] text-3xl font-bold text-primary mb-2">
              BarberSync
            </h1>
            <p class="text-base-content/70">Masukkan email Anda untuk reset kata sandi</p>
          </div>

          <form @submit.prevent="handleSubmit" class="space-y-4">
            <div>
              <label class="label">
                <span class="label-text font-semibold">Email</span>
              </label>
              <input
                x-model="email"
                type="email"
                class="input input-bordered w-full bg-base-100"
                placeholder="contoh@email.com"
                required
              />
            </div>

            <button type="submit" class="btn btn-primary w-full">
              <span x-show="!loading">Kirim Tautan Reset</span>
              <span x-show="loading" class="loading loading-spinner loading-sm"></span>
            </button>
          </form>

          <p class="text-center text-sm text-base-content/70">
            Ingat kata sandi Anda?
            <a href="/login" class="link link-primary font-semibold">Masuk di sini</a>
          </p>
        </div>

        <template x-if="message">
          <div class="alert mt-4" :class="messageType === 'error' ? 'alert-error' : 'alert-success'">
            <p x-text="message"></p>
          </div>
        </template>
      </div>
    </div>
  </div>

  <%- include('partials/bottomNavbar') %>
</div>

<script>
  function forgotPasswordApp() {
    return {
      currentPage: "forgot-password",
      theme: localStorage.getItem("barbersync-theme") || "business",
      email: "",
      loading: false,
      message: "",
      messageType: "success",

      setTheme(value) {
        this.theme = value;
        document.documentElement.setAttribute("data-theme", value);
        localStorage.setItem("barbersync-theme", value);
      },

      handleSubmit() {
        this.loading = true;

        setTimeout(() => {
          if (this.email) {
            this.message = "Tautan reset sudah dikirim ke email Anda";
            this.messageType = "success";
          } else {
            this.message = "Email harus diisi";
            this.messageType = "error";
          }
          this.loading = false;
        }, 1200);
      },

      init() {
        this.setTheme(this.theme);
      },
    };
  }
</script>