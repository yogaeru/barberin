  </main>

  <script>
    function homeApp() {
      return {
        currentPage: "index",
        theme: localStorage.getItem("barbersync-theme") || "coffee",
        services: [],
        searchQuery: "",
        user: null,
        get filteredServices() {
          if (!this.searchQuery) return this.services;
          const q = this.searchQuery.toLowerCase();
          return this.services.filter(s => s.namaService.toLowerCase().includes(q));
        },
        setTheme(value) {
          this.theme = value;
          document.documentElement.setAttribute("data-theme", value);
          localStorage.setItem("barbersync-theme", value);
        },
        init() {
          this.setTheme(this.theme);
          try { const u = localStorage.getItem("barbersync-user"); if (u) this.user = JSON.parse(u); } catch(e) {}
          const stored = <%- JSON.stringify(services.map(s => ({ serviceId: s.serviceId, namaService: s.namaService, harga: s.harga, durasi: s.durasi }))) %>;
          this.services = stored;
        }
      };
    }
  </script>
