    <!-- Operating Hours & CTA -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6">
      <div
        class="bg-base-100/20 backdrop-blur-sm rounded-2xl p-6 border-2 border-base-content/10"
      >
        <h3
          class="font-serif text-xl lg:text-2xl font-semibold text-base-content mb-4"
        >
