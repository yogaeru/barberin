<section class="space-y-6">
  <div class="space-y-2">
    <p class="text-xs uppercase tracking-[0.35em] text-primary font-semibold">Staf & Jadwal</p>
    <h2 class="text-3xl lg:text-4xl font-bold">Daftar Kapster</h2>
    <p class="text-base-content/70 max-w-3xl">Aktifkan atau non-aktifkan kapster untuk hari ini. Perubahan tersimpan di memori server demo.</p>
  </div>

  <section class="bg-base-100/20 backdrop-blur-sm rounded-2xl border border-base-content/10 p-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% barbers.forEach((b) => { %>
        <div class="bg-base-100/10 p-4 rounded-2xl flex flex-col justify-between">
          <div>
            <h3 class="font-semibold text-base-content"><%= b.name %></h3>
            <p class="text-sm text-base-content/70"><%= b.role %></p>
            <p class="text-xs text-base-content/60 mt-2">Terakhir aktif: <%= b.lastActive %></p>
          </div>
          <div class="mt-4 flex items-center justify-between">
            <span class="text-sm font-semibold <%= b.availableToday ? 'text-success' : 'text-error' %>"><%= b.availableToday ? 'Aktif Hari Ini' : 'Non-aktif' %></span>
            <a href="/admin/kapster/toggle/<%= b.barberId %>" class="btn btn-sm <%= b.availableToday ? 'btn-outline' : 'btn-primary' %>"><%= b.availableToday ? 'Non-aktifkan' : 'Aktifkan' %></a>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
</section>
